# ─── Supabase PostgreSQL ──────────────────────────────────────────────────────
# Pegue em: Supabase Dashboard → Project Settings → Database → Connection string
# Use a string com pgbouncer para o app (serverless/Vercel):
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Use a string DIRETA para rodar migrations e ETL local:
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://seu-projeto.vercel.app"
NEXT_PUBLIC_TARGET_CITY="PENHA"
NEXT_PUBLIC_TARGET_STATE="SC"

# ─── ETL (só necessário ao rodar localmente) ──────────────────────────────────
TARGET_CITY="PENHA"
TARGET_STATE="SC"
TARGET_CITY_IBGE="4212908"

GEOCODING_PROVIDER="nominatim"
NOMINATIM_EMAIL="seu@email.com"
GEOCODE_CITY_FALLBACK="true"
GEOCODE_DELAY_MS="1200"

DATA_INPUT_PATH="./data/input"
DATA_OUTPUT_PATH="./data/output"
IMPORT_BATCH_SIZE="500"
